<script>
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
//  мғҒнғң
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
let kospiIndex = 0, nasdaqIndex = 0, usdkrw = 0;
let kospiChgPct = 0, nasdaqChgPct = 0;
let rows  = [];   // {etfName,drop,startPrice,weight,etfPrice,done,stopLoss}
let pnls  = [];   // {date,etfName,buyPrice,sellPrice,qty}
let memos = [];

const COLORS = ['#1967d2','#d93025','#137333','#e37400','#7b2d8b','#0077b6','#c62828','#2e7d32','#f57f17','#4a148c','#01579b','#b71c1c'];

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
//  Yahoo Finance н”„лЎқмӢң fetch (нҳ„мһ¬к°Җ)
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
async function yahooFetch(ticker) {
  const url = `https://query2.finance.yahoo.com/v8/finance/chart/${encodeURIComponent(ticker)}?interval=1d&range=1d`;
  const proxies = [
    `https://corsproxy.io/?url=${encodeURIComponent(url)}`,
    `https://api.allorigins.win/raw?url=${encodeURIComponent(url)}`
  ];
  for (const p of proxies) {
    try {
      const res = await fetch(p, { signal: AbortSignal.timeout(10000) });
      if (!res.ok) continue;
      const j = await res.json();
      const meta = j?.chart?.result?.[0]?.meta;
      if (!meta) continue;
      return {
        price: meta.regularMarketPrice,
        prev:  meta.chartPreviousClose || meta.previousClose || 0,
        cap:   meta.marketCap || 0
      };
    } catch(e) {}
  }
  return null;
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
//  м „мІҙ м—…лҚ°мқҙнҠё (м§ҖмҲҳ + нҷҳмңЁ)
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
async function fetchAll() {
  document.getElementById('kospiVal').textContent  = 'вҖҰ';
  document.getElementById('nasdaqVal').textContent = 'вҖҰ';
  document.getElementById('fxVal').textContent     = 'вҖҰ';

  const [kp, nq, fx] = await Promise.all([
    yahooFetch('^KS11'),
    yahooFetch('^IXIC'),
    yahooFetch('USDKRW=X')
  ]);

  const fmt  = (v,d=2) => v == null ? 'вҖ”' : parseFloat(v).toLocaleString('ko-KR',{minimumFractionDigits:d,maximumFractionDigits:d});
  const chgEl = (elId, price, prev) => {
    const el = document.getElementById(elId);
    if (!price || !prev) { el.textContent='вҖ”'; el.className='index-chg chg-flat'; return; }
    const pct = (price - prev) / prev * 100;
    el.textContent = (pct>=0?'+':'') + pct.toFixed(2)+'%';
    el.className = 'index-chg ' + (pct>0?'chg-up':pct<0?'chg-dn':'chg-flat');
    return pct;
  };

  if (kp) {
    kospiIndex = kp.price;
    kospiChgPct = chgEl('kospiChg', kp.price, kp.prev);
    document.getElementById('kospiVal').textContent = fmt(kp.price);
  } else document.getElementById('kospiVal').textContent = 'мҲҳлҸҷмһ…л Ҙ';

  if (nq) {
    nasdaqIndex = nq.price;
    nasdaqChgPct = chgEl('nasdaqChg', nq.price, nq.prev);
    document.getElementById('nasdaqVal').textContent = fmt(nq.price);
  } else document.getElementById('nasdaqVal').textContent = 'мҲҳлҸҷмһ…л Ҙ';

  if (fx) {
    usdkrw = fx.price;
    document.getElementById('fxVal').textContent = fmt(fx.price, 1);
    chgEl('fxChg', fx.price, fx.prev);
  } else document.getElementById('fxVal').textContent = 'мҲҳлҸҷ';

  const now = new Date();
  document.getElementById('lastUpdated').textContent =
    `мөңмў…мЎ°нҡҢ: ${now.getHours()}:${String(now.getMinutes()).padStart(2,'0')}`;

  recalcAll();
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
//  м§ҖмҲҳ мҲҳлҸҷ нҺём§‘
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
function editIndex(which) {
  const elId = which==='kospi'?'kospiVal':'nasdaqVal';
  const cur  = which==='kospi'?kospiIndex:nasdaqIndex;
  const v = prompt((which==='kospi'?'KOSPI':'NASDAQ')+' м§ҖмҲҳлҘј мһ…л Ҙн•ҳм„ёмҡ”:', cur||'');
  if (v===null) return;
  const n = parseFloat(v.replace(/,/g,''));
  if (isNaN(n)) return;
  if (which==='kospi') kospiIndex=n;
  else nasdaqIndex=n;
  document.getElementById(elId).textContent = n.toLocaleString('ko-KR',{minimumFractionDigits:2,maximumFractionDigits:2});
  recalcAll();
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
//  нҲ¬мһҗкёҲ нҢҢмӢұ
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
function parseTotal(s) {
  if (!s) return 0;
  s = s.trim().replace(/,/g,'');
  const m = s.match(/([\d.]+)\s*([м–өл§ҢмІң])?/);
  if (!m) return parseFloat(s)||0;
  let n = parseFloat(m[1]);
  if (m[2]==='м–ө') n*=100000000;
  else if (m[2]==='л§Ң') n*=10000;
  else if (m[2]==='мІң') n*=1000;
  return Math.round(n);
}
function getTotal() { return parseTotal(document.getElementById('totalInput').value); }
function onTotalChange() {
  const t = getTotal();
  const el = document.getElementById('totalDisplay');
  if (t>=100000000) el.textContent='= '+( t/100000000).toFixed(t%100000000===0?0:2)+'м–өмӣҗ';
  else if (t>=10000) el.textContent='= '+(t/10000).toFixed(0)+'л§Ңмӣҗ';
  else el.textContent='= '+t.toLocaleString('ko-KR')+'мӣҗ';
  recalcAll();
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
//  н”„лҰ¬м…Ӣ
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
function applyPreset(cnt, dropStep) {
  rows = [];
  const w = Math.floor(100/cnt);
  for (let i=0;i<cnt;i++) {
    rows.push({ etfName:'', drop: String((i+1)*dropStep), startPrice:'', weight: String(i===cnt-1?100-(w*(cnt-1)):w), etfPrice:'', done:false, stopLoss:'' });
  }
  renderTable(); recalcAll();
}
function clearRows() { rows=[]; addRow(); addRow(); addRow(); renderTable(); recalcAll(); }

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
//  н…Ңмқҙлё” л ҢлҚ”
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
function addRow() {
  rows.push({ etfName:'', drop:'', startPrice:'', weight:'', etfPrice:'', done:false, stopLoss:'' });
  renderTable(); recalcAll();
}
function deleteRow(i) { rows.splice(i,1); renderTable(); recalcAll(); }
function toggleDone(i,v) { rows[i].done=v; renderTable(); recalcAll(); }

function getEntryIndexDisplay(drop) {
  if (!drop) return 'вҖ”';
  const d = parseFloat(drop)||0;
  let html='';
  if (kospiIndex>0)  html+=`<span style="color:#1967d2;font-size:0.78rem">K ${(kospiIndex*(1-d/100)).toLocaleString('ko-KR',{maximumFractionDigits:0})}</span>`;
  if (nasdaqIndex>0) html+=(html?' ':'')+'<span style="color:#d93025;font-size:0.78rem">N '+(nasdaqIndex*(1-d/100)).toLocaleString('ko-KR',{maximumFractionDigits:0})+'</span>';
  return html||'вҖ”';
}

function renderTable() {
  const tbody = document.getElementById('planBody');
  tbody.innerHTML = '';
  rows.forEach((r,i) => {
    const tr = document.createElement('tr');
    if (r.done) tr.className='done-row';
    const drop = parseFloat(r.drop)||0;
    const startP = parseFloat((r.startPrice||'').replace(/,/g,''))||0;
    const etfEntry = startP>0&&drop>0 ? (startP*(1-drop/100)).toFixed(0) : (r.etfPrice||'');
    // мҶҗм Ҳк°Җ: л§Өмһ…лӢЁк°Җ * 0.9 (10% н•ҳлқҪ)
    const stopLoss = parseFloat(etfEntry)>0 ? Math.round(parseFloat(etfEntry)*0.9).toLocaleString('ko-KR') : 'вҖ”';
    // лӘ©н‘ңлӢЁк°Җ
    const targetRate = parseFloat(document.getElementById('targetRate')?.value||20);
    const targetPrice = parseFloat(etfEntry)>0 ? Math.round(parseFloat(etfEntry)*(1+targetRate/100)).toLocaleString('ko-KR') : 'вҖ”';

    tr.innerHTML = `
      <td><input type="checkbox" class="check-done" ${r.done?'checked':''} onchange="toggleDone(${i},this.checked)"></td>
      <td style="color:#aaa;font-size:0.75rem">${i+1}</td>
      <td><input class="cell etf-name" type="text" value="${r.etfName||''}" placeholder="ETFлӘ…" oninput="rows[${i}].etfName=this.value"></td>
      <td><input class="cell" type="number" value="${r.drop||''}" placeholder="%" step="0.5" min="0" oninput="onDropChange(${i},this.value)" style="width:60px"></td>
      <td><input class="cell" type="text" value="${r.startPrice||''}" placeholder="нҳ„мһ¬ETFк°Җ" oninput="onStartChange(${i},this.value)" style="width:80px"></td>
      <td id="entryIdx_${i}" class="cell-display" style="font-size:0.78rem">${getEntryIndexDisplay(r.drop)}</td>
      <td style="color:#137333;font-weight:700;font-size:0.8rem">${targetPrice}</td>
      <td><input class="cell" type="number" value="${r.weight||''}" placeholder="%" step="1" min="0" max="100" oninput="onWeightChange(${i},this.value)" style="width:55px"></td>
      <td id="amt_${i}" class="cell-display">вҖ”</td>
      <td><input class="cell" id="etfInput_${i}" type="text" value="${etfEntry||''}" placeholder="лӢЁк°Җ" oninput="onEtfChange(${i},this.value)" style="width:80px"></td>
      <td id="qty_${i}" class="cell-qty">вҖ”</td>
      <td style="color:#e37400;font-size:0.8rem;font-weight:700">${stopLoss}</td>
      <td><button class="btn-del" onclick="deleteRow(${i})">вң•</button></td>
    `;
    tbody.appendChild(tr);
  });
}

function onDropChange(i,v)    { rows[i].drop=v; recalcRow(i); renderTable(); }
function onStartChange(i,v)   { rows[i].startPrice=v.replace(/,/g,''); recalcRow(i); renderTable(); }
function onWeightChange(i,v)  { rows[i].weight=v; recalcRow(i); }
function onEtfChange(i,v)     { rows[i].etfPrice=v.replace(/,/g,''); recalcRow(i); }

function recalcRow(i) {
  const total = getTotal();
  const row = rows[i];
  const drop   = parseFloat(row.drop)||0;
  const weight = parseFloat(row.weight)||0;
  const amt    = weight>0 ? Math.round(total*weight/100) : 0;
  const startP = parseFloat((row.startPrice||'').replace(/,/g,''))||0;
  let etfForCalc = parseFloat((row.etfPrice||'').replace(/,/g,''))||0;
  if (startP>0 && drop>0) etfForCalc = startP*(1-drop/100);

  const idxEl = document.getElementById('entryIdx_'+i);
  if (idxEl) idxEl.innerHTML = getEntryIndexDisplay(drop);
  const amtEl = document.getElementById('amt_'+i);
  if (amtEl) amtEl.textContent = amt>0 ? amt.toLocaleString('ko-KR') : 'вҖ”';
  const qty = (etfForCalc>0&&amt>0) ? Math.floor(amt/etfForCalc) : 0;
  const qtyEl = document.getElementById('qty_'+i);
  if (qtyEl) qtyEl.textContent = qty>0 ? qty.toLocaleString('ko-KR') : 'вҖ”';
  updateSummary();
}

function recalcAll() { rows.forEach((_,i)=>recalcRow(i)); drawDonut(); }

function updateSummary() {
  const total=getTotal();
  let sumW=0, sumA=0, sumQty=0, doneCount=0;
  rows.forEach((r,i)=>{
    const w=parseFloat(r.weight)||0; sumW+=w;
    sumA+=Math.round(total*w/100);
    const qEl=document.getElementById('qty_'+i);
    if(qEl) sumQty+=parseInt(qEl.textContent.replace(/,/g,''))||0;
    if(r.done) doneCount++;
  });
  const sb = document.getElementById('summaryBar');
  const over = sumW>100.05;
  sb.className = 'summary-bar'+(over?' weight-warn':'');
  document.getElementById('sumWeight').textContent = sumW.toFixed(1);
  document.getElementById('sumAmt').textContent    = sumA.toLocaleString('ko-KR');
  document.getElementById('sumDone').textContent   = doneCount;
  const avgP = (sumQty>0&&sumA>0)?Math.round(sumA/sumQty):0;
  document.getElementById('sumQty').textContent      = sumQty>0?sumQty.toLocaleString('ko-KR'):'вҖ”';
  document.getElementById('avgPrice').textContent    = avgP>0?avgP.toLocaleString('ko-KR'):'вҖ”';
  document.getElementById('sumAmtTotal').textContent = sumA>0?sumA.toLocaleString('ko-KR'):'вҖ”';
  const tr = parseFloat(document.getElementById('targetRate')?.value||20)/100;
  document.getElementById('targetAmt').textContent   = sumA>0?Math.round(sumA*(1+tr)).toLocaleString('ko-KR'):'вҖ”';
  if(over) showToast('вҡ  л№„мӨ‘ н•©кі„к°Җ 100%лҘј мҙҲкіјн–ҲмҠөлӢҲлӢӨ!');
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
//  лҸ„л„ӣ м°ЁнҠё
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
function drawDonut() {
  const canvas = document.getElementById('donutCanvas');
  const ctx    = canvas.getContext('2d');
  const cx=70,cy=70,R=60,r=38;
  ctx.clearRect(0,0,140,140);
  const data = rows.map((r,i)=>({
    label: r.etfName||`кө¬к°„${i+1}`,
    w: parseFloat(r.weight)||0,
    color: COLORS[i%COLORS.length]
  })).filter(d=>d.w>0);
  const total = data.reduce((s,d)=>s+d.w,0)||1;
  let angle = -Math.PI/2;
  data.forEach(d=>{
    const slice = (d.w/total)*2*Math.PI;
    ctx.beginPath(); ctx.moveTo(cx,cy);
    ctx.arc(cx,cy,R,angle,angle+slice);
    ctx.closePath(); ctx.fillStyle=d.color; ctx.fill();
    angle+=slice;
  });
  ctx.beginPath(); ctx.arc(cx,cy,r,0,2*Math.PI);
  ctx.fillStyle='#fff'; ctx.fill();
  ctx.fillStyle='#1a1a2e'; ctx.font='bold 13px Segoe UI';
  ctx.textAlign='center'; ctx.textBaseline='middle';
  const sumW = rows.reduce((s,r)=>s+(parseFloat(r.weight)||0),0);
  ctx.fillText(sumW.toFixed(0)+'%',cx,cy);

  const legend = document.getElementById('donutLegend');
  legend.innerHTML = data.map(d=>`
    <div class="legend-item">
      <div class="legend-dot" style="background:${d.color}"></div>
      <span>${d.label} <strong>${d.w}%</strong></span>
    </div>`).join('');
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
//  мӢӨнҳ„мҶҗмқө
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
function addPnl() {
  const today = new Date();
  pnls.push({ date: today.toISOString().slice(0,10), etfName:'', buyPrice:'', sellPrice:'', qty:'' });
  renderPnl();
}
function deletePnl(i) { pnls.splice(i,1); renderPnl(); }
function renderPnl() {
  const tbody = document.getElementById('pnlBody');
  tbody.innerHTML='';
  let totalProfit=0, hasData=false;
  pnls.forEach((p,i)=>{
    const bp=parseFloat((p.buyPrice||'').replace(/,/g,''))||0;
    const sp=parseFloat((p.sellPrice||'').replace(/,/g,''))||0;
    const qty=parseFloat((p.qty||'').replace(/,/g,''))||0;
    const profit = (bp>0&&sp>0&&qty>0) ? Math.round((sp-bp)*qty) : null;
    const pctStr = (bp>0&&sp>0) ? ((sp-bp)/bp*100).toFixed(2)+'%' : 'вҖ”';
    const cls    = profit==null?'':profit>=0?'pnl-pos':'pnl-neg';
    if(profit!=null){totalProfit+=profit;hasData=true;}
    const tr=document.createElement('tr');
    tr.innerHTML=`
      <td><input class="cell" type="date" value="${p.date||''}" oninput="pnls[${i}].date=this.value" style="width:110px"></td>
      <td><input class="cell etf-name" type="text" value="${p.etfName||''}" placeholder="ETFлӘ…" oninput="pnls[${i}].etfName=this.value"></td>
      <td><input class="cell" type="text" value="${p.buyPrice||''}" placeholder="л§ӨмҲҳлӢЁк°Җ" oninput="pnls[${i}].buyPrice=this.value;renderPnl()" style="width:80px"></td>
      <td><input class="cell" type="text" value="${p.sellPrice||''}" placeholder="л§ӨлҸ„лӢЁк°Җ" oninput="pnls[${i}].sellPrice=this.value;renderPnl()" style="width:80px"></td>
      <td><input class="cell" type="text" value="${p.qty||''}" placeholder="мҲҳлҹү" oninput="pnls[${i}].qty=this.value;renderPnl()" style="width:55px"></td>
      <td class="${cls}">${profit!=null?profit.toLocaleString('ko-KR'):'вҖ”'}</td>
      <td class="${cls}">${pctStr}</td>
      <td><button class="btn-del" onclick="deletePnl(${i})">вң•</button></td>
    `;
    tbody.appendChild(tr);
  });
  const totalEl=document.getElementById('pnlTotal');
  if(hasData){
    totalEl.style.display='block';
    totalEl.innerHTML=`мҙқ мӢӨнҳ„мҶҗмқө: <span class="${totalProfit>=0?'pnl-pos':'pnl-neg'}">${totalProfit.toLocaleString('ko-KR')}мӣҗ</span>`;
  } else totalEl.style.display='none';
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
//  TOP 20 мЎ°нҡҢ (нҳ„мһ¬к°Җ мӢӨмӢңк°„)
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
const TOP20 = {
  kospi: [
    ['мӮјм„ұм „мһҗ','005930.KS'],['SKн•ҳмқҙлӢүмҠӨ','000660.KS'],['мӮјм„ұл°”мқҙмҳӨлЎңм§ҒмҠӨ','207940.KS'],
    ['LGм—җл„Ҳм§ҖмҶ”лЈЁм…ҳ','373220.KS'],['нҳ„лҢҖм°Ё','005380.KS'],['мӮјм„ұSDI','006400.KS'],
    ['кё°м•„','000270.KS'],['POSCOнҷҖл”©мҠӨ','005490.KS'],['NAVER','035420.KS'],
    ['LGнҷ”н•ҷ','051910.KS'],['мӮјм„ұл¬јмӮ°','028260.KS'],['нҳ„лҢҖлӘЁл№„мҠӨ','012330.KS'],
    ['KBкёҲмңө','105560.KS'],['м…ҖнҠёлҰ¬мҳЁ','068270.KS'],['мӢ н•ңм§ҖмЈј','055550.KS'],
    ['LGм „мһҗ','066570.KS'],['м№ҙм№ҙмҳӨ','035720.KS'],['н•ҳлӮҳкёҲмңөм§ҖмЈј','086790.KS'],
    ['н•ңкөӯм „л Ҙ','015760.KS'],['л‘җмӮ°м—җл„Ҳл№ҢлҰ¬нӢ°','034020.KS']
  ],
  nasdaq: [
    ['Apple','AAPL'],['Microsoft','MSFT'],['NVIDIA','NVDA'],['Amazon','AMZN'],
    ['Meta','META'],['Alphabet A','GOOGL'],['Alphabet C','GOOG'],['Tesla','TSLA'],
    ['Broadcom','AVGO'],['Netflix','NFLX'],['Costco','COST'],['AMD','AMD'],
    ['T-Mobile','TMUS'],['PepsiCo','PEP'],['Qualcomm','QCOM'],['Intuitive Surg','ISRG'],
    ['Texas Inst','TXN'],['Booking','BKNG'],['Palo Alto','PANW'],['Lam Research','LRCX']
  ]
};

async function fetchTop20(market) {
  const bodyEl = document.getElementById(market+'TopBody');
  const updEl  = document.getElementById(market+'TopUpdated');
  bodyEl.innerHTML = '<div class="top20-loading">нҳ„мһ¬к°Җ мЎ°нҡҢ мӨ‘вҖҰ</div>';

  const results = await Promise.all(
    TOP20[market].map(([,sym]) => yahooFetch(sym))
  );

  const items = TOP20[market].map(([name,sym],i)=>({
    name, sym,
    price: results[i]?.price,
    prev:  results[i]?.prev,
    cap:   results[i]?.cap||0
  })).filter(r=>r.price).sort((a,b)=>b.cap-a.cap);

  if (!items.length) {
    bodyEl.innerHTML='<div class="top20-loading">вҡ  мЎ°нҡҢ мӢӨнҢЁ вҖ” GitHub Pagesм—җм„ң мӢӨн–үн•ҳм„ёмҡ”</div>';
    return;
  }

  const fmtCap = v => {
    if (!v) return 'вҖ”';
    if (market==='kospi') {
      if (v>=1e12) return (v/1e12).toFixed(1)+'мЎ°';
      return (v/1e8).toFixed(0)+'м–ө';
    }
    if (v>=1e12) return '$'+(v/1e12).toFixed(2)+'T';
    return '$'+(v/1e9).toFixed(0)+'B';
  };
  const fmtP = v => v==null?'вҖ”':parseFloat(v).toLocaleString('ko-KR',{minimumFractionDigits:2,maximumFractionDigits:2});

  let html=`<table class="top20-table"><thead><tr>
    <th>#</th><th>мў…лӘ©</th><th>нҳ„мһ¬к°Җ</th><th>л“ұлқҪлҘ </th><th>мӢңк°Җмҙқм•Ў</th>
  </tr></thead><tbody>`;

  items.forEach((r,idx)=>{
    const pct = (r.prev&&r.price) ? (r.price-r.prev)/r.prev*100 : null;
    const cls = pct==null?'chg-flat':pct>0?'chg-up':'chg-dn';
    const pctStr = pct==null?'вҖ”':(pct>0?'+':'')+pct.toFixed(2)+'%';
    html+=`<tr>
      <td>${idx+1}</td>
      <td>${r.name}</td>
      <td>${fmtP(r.price)}</td>
      <td class="${cls}">${pctStr}</td>
      <td>${fmtCap(r.cap)}</td>
    </tr>`;
  });
  html+='</tbody></table>';
  bodyEl.innerHTML=html;
  const now=new Date();
  updEl.textContent=`${now.getHours()}:${String(now.getMinutes()).padStart(2,'0')} кё°мӨҖ`;
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
//  CSV лӮҙліҙлӮҙкё°
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
function exportCSV() {
  const total=getTotal();
  let csv='#,ETFлӘ…,н•ҳлқҪнҸӯ(%),мҠӨнғҖнҠёлӢЁк°Җ,м§„мһ…KOSPI,м§„мһ…NASDAQ,л№„мӨ‘(%),нҲ¬мһҗкёҲ(мӣҗ),ETFлӢЁк°Җ(мӣҗ),л§Өмһ…мҲҳлҹү,лӘ©н‘ңлӢЁк°Җ,мҶҗм Ҳк°Җ,мҷ„лЈҢ\n';
  rows.forEach((r,i)=>{
    const drop=parseFloat(r.drop)||0;
    const startP=parseFloat((r.startPrice||'').replace(/,/g,''))||0;
    const etfE=startP>0&&drop>0?(startP*(1-drop/100)).toFixed(0):(r.etfPrice||'');
    const w=parseFloat(r.weight)||0;
    const amt=w>0?Math.round(total*w/100):0;
    const qty=parseFloat(etfE)>0&&amt>0?Math.floor(amt/parseFloat(etfE)):0;
    const kEntry=kospiIndex>0?(kospiIndex*(1-drop/100)).toFixed(0):'';
    const nEntry=nasdaqIndex>0?(nasdaqIndex*(1-drop/100)).toFixed(0):'';
    const tr=parseFloat(document.getElementById('targetRate').value||20)/100;
    const targetP=parseFloat(etfE)>0?Math.round(parseFloat(etfE)*(1+tr)):'';
    const stopL=parseFloat(etfE)>0?Math.round(parseFloat(etfE)*0.9):'';
    csv+=`${i+1},"${r.etfName||''}",${r.drop||''},${r.startPrice||''},${kEntry},${nEntry},${r.weight||''},${amt},${etfE},${qty},${targetP},${stopL},${r.done?'мҷ„лЈҢ':''}\n`;
  });
  const blob=new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8'});
  const a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download='л¶„н• л§ӨмҲҳн”Ңлһң.csv';
  a.click();
}

