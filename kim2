// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
//  м ҖмһҘ / л¶Ҳлҹ¬мҳӨкё°
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
function saveAll() {
  const sumW=rows.reduce((s,r)=>s+(parseFloat(r.weight)||0),0);
  if(sumW>100.05){ if(!confirm('л№„мӨ‘ н•©кі„к°Җ '+sumW.toFixed(1)+'%мһ…лӢҲлӢӨ. к·ёлһҳлҸ„ м ҖмһҘн• к№Ңмҡ”?')) return; }
  const data={
    total: document.getElementById('totalInput').value,
    kospi: kospiIndex, nasdaq: nasdaqIndex, usdkrw,
    targetRate: document.getElementById('targetRate').value,
    rows, pnls, memos
  };
  try { localStorage.setItem('dcaPlanner_v4',JSON.stringify(data)); showToast('вң“ м ҖмһҘлҗҳм—ҲмҠөлӢҲлӢӨ'); }
  catch(e){ showToast('вҡ  м ҖмһҘ мӢӨнҢЁ'); }
}

function loadAll() {
  const raw=localStorage.getItem('dcaPlanner_v4') || localStorage.getItem('dcaPlanner_v3');
  if(!raw) return;
  try {
    const d=JSON.parse(raw);
    const fmt=v=>v?parseFloat(v).toLocaleString('ko-KR',{minimumFractionDigits:2,maximumFractionDigits:2}):'вҖ”';
    if(d.total){ document.getElementById('totalInput').value=d.total; onTotalChange(); }
    if(d.kospi){ kospiIndex=d.kospi; document.getElementById('kospiVal').textContent=fmt(d.kospi); }
    if(d.nasdaq){ nasdaqIndex=d.nasdaq; document.getElementById('nasdaqVal').textContent=fmt(d.nasdaq); }
    if(d.usdkrw){ usdkrw=d.usdkrw; document.getElementById('fxVal').textContent=fmt(d.usdkrw); }
    if(d.targetRate) document.getElementById('targetRate').value=d.targetRate;
    if(d.rows) rows=d.rows.map(r=>({
      etfName:r.etfName||'', drop:r.drop||'', startPrice:r.startPrice||'',
      weight:r.weight||'', etfPrice:r.etfPrice||'', done:r.done||false
    }));
    if(d.pnls) pnls=d.pnls;
    if(d.memos) memos=d.memos;
  } catch(e){}
}

function showToast(msg) {
  const t=document.getElementById('toast');
  t.textContent=msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2500);
}

// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
//  мҙҲкё°нҷ”
// в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
window.onload = function() {
  loadAll();
  if(rows.length===0){ addRow(); addRow(); addRow(); }
  renderTable();
  renderPnl();
  renderMemos();
  recalcAll();
  drawDonut();
  fetchAll();
};
